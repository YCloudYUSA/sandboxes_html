<a class="ping-pong-card group {{ 'ping-pong-card--reverse' if loop.index0 % 2 == 1 }}"
   id="{{ card.id }}" href="{{ card.link }}" title="Preview {{ card.title }}" target="{{ card.id }}">
    <div class="ping-pong-image">
        <div class="sandbox-card-header"></div>
    </div>
    <div class="ping-pong-content">
        <h3 class="font-quicksand text-brand-teal-dark text-2xl lg:text-3xl font-bold mb-3">{{ card.title }}</h3>
        <div class="w-14 h-[3px] bg-brand-blue mb-5"></div>
        <p class="text-dark-gray text-base lg:text-lg leading-relaxed mb-6">{{ card.description | safe }}</p>
        <span class="ping-pong-button">Preview <i class="external-icon"></i></span>
    </div>
</a>
