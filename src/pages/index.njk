{% extends "layouts/base.njk" %}

{% block banner %}
    <div class="hero-banner">
        <div class="hero-banner-inner">
            <div class="hero-banner-content">
                <h1 class="font-quicksand text-white text-4xl lg:text-[52px] font-bold leading-tight mb-4">{{ header }}</h1>
                <p class="text-white/90 text-base lg:text-lg max-w-[600px] leading-relaxed">{{ intro }}</p>
            </div>
        </div>
        <div class="hero-banner-chevron hero-banner-chevron--left">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 322 520" fill="rgba(255,255,255,0.08)">
                <path d="m131.325 241.357.025.048v-.048h-.025Zm181.701 3.28-1.144-1.864L183.89 32.532l-2.239-3.657C170.805 11.017 149.983 0 126.872 0H21.32C9.553 0 0 9.059 0 20.217c0 3.468.846 6.795 2.537 9.578l128.838 211.61c5.896 9.507 9.254 20.571 9.254 32.39 0 11.819-3.184 22.222-8.757 31.541L19.877 489.344c-1.692 2.76-2.538 6.086-2.538 9.578 0 11.158 9.553 20.217 21.32 20.217h108.289c23.111 0 43.933-11.017 54.779-28.852l2.239-3.68 107.717-176.931 1.99-3.279c5.498-9.035 8.035-19.344 8.035-30.314 0-10.97-3.085-22.246-8.707-31.446h.025Z"/>
            </svg>
        </div>
        <div class="hero-banner-chevron hero-banner-chevron--right">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 322 520" fill="rgba(255,255,255,0.1)">
                <path d="m131.325 241.357.025.048v-.048h-.025Zm181.701 3.28-1.144-1.864L183.89 32.532l-2.239-3.657C170.805 11.017 149.983 0 126.872 0H21.32C9.553 0 0 9.059 0 20.217c0 3.468.846 6.795 2.537 9.578l128.838 211.61c5.896 9.507 9.254 20.571 9.254 32.39 0 11.819-3.184 22.222-8.757 31.541L19.877 489.344c-1.692 2.76-2.538 6.086-2.538 9.578 0 11.158 9.553 20.217 21.32 20.217h108.289c23.111 0 43.933-11.017 54.779-28.852l2.239-3.68 107.717-176.931 1.99-3.279c5.498-9.035 8.035-19.344 8.035-30.314 0-10.97-3.085-22.246-8.707-31.446h.025Z"/>
            </svg>
        </div>
    </div>
{% endblock %}

{% block content %}
    {% for section in sections %}
    <section class="mb-8 sm:mb-12 lg:mb-16">
        <h2 class="font-quicksand text-brand-teal-dark text-3xl lg:text-4xl font-bold text-center mb-6 sm:mb-8 lg:mb-10">{{ section.title }}</h2>
        <div class="flex flex-col gap-6 sm:gap-8 lg:gap-10">
            {% for card in section.cards %}
                {% include "components/card.njk" %}
            {% endfor %}
        </div>
    </section>
    {% endfor %}
{% endblock %}
